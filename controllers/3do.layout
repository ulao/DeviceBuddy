# Simple controller layout file.
# Blocks are separated by a blank line.
# x and y are the center of the shape inside the controller area.
# byte indexes are zero-based: first stream byte is byte 0.

name: Bliss-Box Test Controller
width: 420
height: 260
# D-pad: max 1.
# Leave byte/bit values off if you only want a static d-pad shape.
type: dpad
id:POV
x: 90
y: 130
arrange: left
byte: 11
upData: 0
uprightData: 1
rightData: 2
downrightData: 3
downData: 4
downleftData: 5
leftData: 6
leftupData: 7
shapeType: plus

type: button
id:BTN_SELECT
label: X
x: 185
y: 125
byte: 0
bit: 4
group: center
shapeType: rectangle1

type: button
label: P
id:BTN_START
x: 245
y: 125
byte: 0
bit: 5
group: center
shapeType: rectangle1


# Face buttons. Max buttons total is 24.
# bit is a bit number, so bit 3 means mask 0x08.
type: button
id: BTN_2
label: B
x: 325
y: 130
byte: 0
bit: 1
group: face
shapeType: circle1

type: button
id: BTN_R1
label: C
x: 360
y: 115
byte: 0
bit: 7
group: face
shapeType: circle1

type: button
id: BTN_1
label: A
x: 290
y: 145
byte: 0
bit: 0
group: face
shapeType: circle1

type: button
label: L1
id:BTN_L1
x: 90
y: 35
byte: 1
bit: 0
group: top
shapeType: rectangle2

type: button
label: R1
id:BTN_R1
x: 330
y: 35
byte: 1
bit: 1
group: top
shapeType: rectangle2

  