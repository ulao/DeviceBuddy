# Simple controller layout file.
# Blocks are separated by a blank line.
# x and y are the center of the shape inside the controller area.
# byte indexes are zero-based: first stream byte is byte 0.

name: Bliss-Box Test Controller
width: 420
height: 260
 

# D-pad: max 1.
# Leave byte/bit values off if you only want a static d-pad shape.
type: dpad
id:POV
x: 110
y: 135
arrange: left
byte: 11
upData: 2
uprightData: 3
rightData: 4
downrightData: 5
downData: 6
downleftData: 7
leftData: 0
leftupData: 1
shapeType: plus

# Face buttons. Max buttons total is 24.
# bit is a bit number, so bit 3 means mask 0x08.
type: button
id: BTN_1
label: A
x: 80
y: 230
byte: 0
bit: 0
group: face
shapeType: circle1

type: button
id: BTN_2
label: B
x: 80
y: 50
byte: 0
bit: 1
group: face
shapeType: circle1

type: button
id: BTN_3
label: X
x: 40
y: 130
byte: 0
bit: 2
group: face
shapeType: circle1
 