# Simple controller layout file.
# Blocks are separated by a blank line.
# x and y are the center of the shape inside the controller area.
# byte indexes are zero-based: first stream byte is byte 0.

name: Bliss-Box Test Controller
width: 420
height: 260
# D-pad: max 1.
# Leave byte/bit values off if you only want a static d-pad shape.
type: dpad
id:POV
x: 90
y: 100
arrange: left
byte: 11
upData: 0
uprightData: 1
rightData: 2
downrightData: 3
downData: 4
downleftData: 5
leftData: 6
leftupData: 7
shapeType: plus

type: button
id:BTN_SELECT
label:  
x: 220
y: 120
byte: 0
bit: 4
group: center
shapeType: rectanglea

type: button
label: 
id:BTN_START
x: 180
y: 120
byte: 0
bit: 5
group: center
shapeType: rectanglea


# Face buttons. Max buttons total is 24.
# bit is a bit number, so bit 3 means mask 0x08.
type: button
id: BTN_2
label: B
x: 325
y: 105
byte: 0
bit: 1
group: face
shapeType: circle1

