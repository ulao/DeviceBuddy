# Simple controller layout file.
# Blocks are separated by a blank line.
# x and y are the center of the shape inside the controller area.
# byte indexes are zero-based: first stream byte is byte 0.

name: Bliss-Box Test Controller
width: 420
height: 260
 

# D-pad: max 1.
# Leave byte/bit values off if you only want a static d-pad shape.
type: dpad
id:POV
x: 95
y: 100
arrange: left
byte: 11
upData: 2
uprightData: 3
rightData: 4
downrightData: 5
downData: 6
downleftData: 7
leftData: 0
leftupData: 1
shapeType: plus

# Face buttons. Max buttons total is 24.
# bit is a bit number, so bit 3 means mask 0x08.
type: button
id: BTN_1
label: 
x: 330
y: 75
byte: 0
bit: 3
group: face
shapeType: circle3

type: button
id: BTN_2
label: 
x: 360
y: 120
byte: 0
bit: 1
group: face
shapeType: circle3

type: button
id: BTN_3
label: 
x: 280
y: 100
byte: 0
bit: 2
group: face
shapeType: circle3

type: button
id: BTN_4
label: 
x: 310
y: 140
byte: 0
bit: 0
group: face
shapeType: circle3
 
type: button
id:BTN_SELECT
label: 
x: 210
y: 125
byte: 0
bit: 4
group: center
shapeType: rectangleb

type: button
label: 
id:BTN_START
x: 210
y: 160
byte: 0
bit: 5
group: center
shapeType: rectangleb