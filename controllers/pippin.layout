# Simple controller layout file.
# Blocks are separated by a blank line.
# x and y are the center of the shape inside the controller area.
# byte indexes are zero-based: first stream byte is byte 0.

name: Bliss-Box Test Controller
width: 420
height: 260

# Analog sticks: up to 8.
# xByte/yByte choose the stream bytes that move the stick.


type: analog
label:  
id:LEFTSTICK
x: 200
y: 105
xByte: 3
yByte: 4
side: right
shapeType: circle2

# D-pad: max 1.
# Leave byte/bit values off if you only want a static d-pad shape.
type: dpad
id:POV
x: 120
y: 120
arrange: left
byte: 11
upData: 0
uprightData: 1
rightData: 2
downrightData: 3
downData: 4
downleftData: 5
leftData: 6
leftupData: 7
shapeType: plus


# Face buttons. Max buttons total is 24.
# bit is a bit number, so bit 3 means mask 0x08.

type: button
label: Y
id:BTN_3
x: 285
y: 90
byte: 0
bit: 2
group: face
shapeType: circle0
 
type: button
label: R
id:BTN_1
x: 295
y: 120
byte: 0
bit: 0
group: face
shapeType: circle0
 
type: button
label: G
id:BTN_2
x: 315
y: 105
byte: 0
bit: 1
group: face
shapeType: circle0

type: button
label: B
id:BTN_4
x: 305
y: 75
byte: 0
bit: 3
group: center
shapeType: circle0

type: button
label: []
id:BTN_SELECT
x: 170
y: 200
byte: 0
bit: 4
group: center
shapeType: circle1

type: button
label: 0
id:BTN_HOME
x: 210
y: 200
byte: 2
bit: 2
group: center
shapeType: circle1

type: button
label: ◇
id:BTN_START
x: 250
y: 200
byte: 0
bit: 5
group: center
shapeType: circle1

 

type: button
label: L1
id:BTN_L1
x: 90
y: 10
byte: 0
bit: 6
group: top
shapeType: rectangle2

type: button
label: R1
id:BTN_R1
x: 330
y: 10
byte: 0
bit: 7
group: top
shapeType: rectangle2
