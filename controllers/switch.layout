# Simple controller layout file.
# Blocks are separated by a blank line.
# x and y are the center of the shape inside the controller area.
# byte indexes are zero-based: first stream byte is byte 0.


# Analog sticks: up to 8.
# xByte/yByte choose the stream bytes that move the stick.
type: analog
label:  
id: LEFTSTICK
x: 110
y: 80
xByte: 3
yByte: 4
side: left
shapeType: circle2

type: analog
label:  
id: RIGHTSTICK
x: 250
y: 140
xByte: 5
yByte: 6
side: right
shapeType: circle2


# D-pad: max 1.
# Leave byte/bit values off if you only want a static d-pad shape.
type: dpad
id: POV
x: 160
y: 140
arrange: left
byte: 2
upData: 00
uprightData:1
rightData: 2
downrightData: 3
downData: 4
downleftData: 5
leftData: 6
leftupData: 7
shapeType: plus

# Face buttons. Max buttons total is 24.
# bit is a bit number, so bit 3 means mask 0x08.
 
type: button
label: +
id: BTN_START
x: 250
y: 65
byte: 1
bit: 1
group: center
shapeType: circle0


type: button
label: Y
id: BTN_4
x: 310
y: 60
byte: 0
bit: 3
group: face
shapeType: circle1

type: button
label: X
id: BTN_3
x: 335
y: 85
byte: 0
bit: 2
group: face
shapeType: circle1

type: button
label: B
id: BTN_2
x: 285
y: 85
byte: 0
bit: 0
group: face
shapeType: circle1

type: button
label: A
id: BTN_1
x: 310
y: 110
byte: 0
bit: 1
group: face
shapeType: circle1


type: button
label: L1
id: BTN_L1
x: 90
y: 10
byte: 0
bit: 4
group: top
shapeType: rectangle2

type: button
label: R1
id: BTN_R1
x: 330
y: 10
byte: 0
bit: 5
group: top
shapeType: rectangle2

type: button
label: -
id: BTN_SELECT
x: 170
y: 65
byte: 1
bit: 0
group: top
shapeType: circle0

type: button
label: L2
id:BTN_L2
x: 90
y: 200
byte: 0
bit: 6
group: top
shapeType: Triangle

type: button
label: R2
id:BTN_R2
x: 293
y: 200
byte: 0
bit: 7
group: top
shapeType: Triangle

type: button
id:BTN_L3
label: L3
label: L3
byte: 1
bit: 2
target: leftStick

type: button
id:BTN_R3
label: R3
byte: 1
bit: 3
target: rightStick

type: button
label: c
id:BTN_MISC2
x: 190
y: 85
byte: 1
bit: 5
group: center
shapeType: circle0

 
type: button
label: ⌂
id:BTN_HOME
x: 230
y: 85
byte: 1
bit: 4
group: center
shapeType: circle0

