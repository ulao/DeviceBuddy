# Simple controller layout file.
# Blocks are separated by a blank line.
# x and y are the center of the shape inside the controller area.
# byte indexes are zero-based: first stream byte is byte 0.

name: Bliss-Box Test Controller
width: 420
height: 260

# Analog sticks: up to 8.
# xByte/yByte choose the stream bytes that move the stick.


# D-pad: max 1.
# Leave byte/bit values off if you only want a static d-pad shape.
type: dpad
id:POV
x: 85
y: 55
arrange: left
byte: 11
upData: 0
uprightData: 1
rightData: 2
downrightData: 3
downData: 4
downleftData: 5
leftData: 6
leftupData: 7
shapeType: plus

# Face buttons. Max buttons total is 24.
# bit is a bit number, so bit 3 means mask 0x08.

type: button
label: B
id:BTN_1
x: 260
y: 90
byte: 0
bit: 0
group: face
shapeType: circle1
 
type: button
label: A
id:BTN_2
x: 290
y: 75
byte: 0
bit: 1
group: face
shapeType: circle1

type: button
label:
id:BTN_SELECT 
x: 135
y: 75
byte: 0
bit: 5
group: center
shapeType: circle1

type: button
label: 
id:BTN_START
x: 165
y: 90
byte: 0
bit: 4
group: center
shapeType: circle1


type: button
label: ◄ 
id:BTN_3
x: 315
y: 55
byte: 0
bit: 2
group: face
shapeType: circle0


type: button
label:  ▼
id:BTN_4
x: 335
y: 75
byte: 0
bit: 3
group: face
shapeType: circle0


type: button
label:  ►
id:BTN_L2
x: 355
y: 55
byte: 1
bit: 1
group: face
shapeType: circle0

type: button
label:  ▲
id:BTN_R2
x: 335
y: 35
byte: 1
bit: 0
group: face
shapeType: circle0


type: button
label: L1
id:BTN_L1
x: 90
y: 10
byte: 0
bit: 6
group: top
shapeType: rectangle2

type: button
label: R1
id:BTN_L2
x: 330
y: 10
byte: 0
bit: 7
group: top
shapeType: rectangle2
