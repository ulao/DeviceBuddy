# Simple controller layout file.
# Blocks are separated by a blank line.
# x and y are the center of the shape inside the controller area.
# byte indexes are zero-based: first stream byte is byte 0.

# Analog sticks: up to 8.
# xByte/yByte choose the stream bytes that move the stick.
type: analog
label:  
id:LEFTSTICK
x: 150
y: 140
xByte: 3
yByte: 4
side: left
shapeType: circle2

type: analog
label:  
id:RIGHTSTICK
x: 270
y: 140
xByte: 6
yByte: 7
side: right
shapeType: circle2

# D-pad: max 1.
# Leave byte/bit values off if you only want a static d-pad shape.
type: dpad
id:POV
x: 90
y: 90
arrange: left
byte: 11
upData: 0
uprightData: 1
rightData: 2
downrightData: 3
downData: 4
downleftData: 5
leftData: 6
leftupData: 7
shapeType: plus

# Face buttons. Max buttons total is 24.
# bit is a bit number, so bit 3 means mask 0x08.
type: button
id:BTN_4
label: x
x: 334
y: 55
byte: 0
bit: 3
group: face
shapeType: circle1

type: button
id:BTN_2
label: a
x: 364
y: 85
byte: 0
bit: 1
group: face
shapeType: circle1

type: button
id:BTN_3
label: y
x: 304
y: 85
byte: 0
bit: 2
group: face
shapeType: circle1

type: button
label: b
id:BTN_1
x: 334
y: 115
byte: 0
bit: 0
group: face
shapeType: circle1

type: button
id:BTN_SELECT
label: -
x: 185
y: 85
byte: 0
bit: 4
group: center
shapeType: circle0

type: button
label: +
id:BTN_START
x: 245
y: 85
byte: 0
bit: 5
group: center
shapeType: circle0

type: button
label: ⌂
id:BTN_HOME
x: 215
y: 85
byte: 2
bit: 2
group: center
shapeType: circle0

type: button
label: L2
id:BTN_L2
x: 90
y: 0
byte: 1
bit: 0
group: top
shapeType: rectangle2

type: button
label: R2
id:BTN_R2
x: 330
y: 0
byte: 1
bit: 1
group: top
shapeType: rectangle2

type: button
label: L1
id:BTN_L1
x: 90
y: 25
byte: 0
bit: 6
group: top
shapeType: rectangle2

type: button
label: R1
id:BTN_R1
x: 330
y: 25
byte: 0
bit: 7
group: top
shapeType: rectangle2


type: button
label: L3
id:BTN_L3
byte: 1
bit: 6
target: leftStick

type: button
label: R3
id:BTN_R3
byte: 1
bit: 7
target: rightStick


